# API (copy to api/.env)
DATABASE_URL="postgresql://teacherbridge:teacherbridge@localhost:5432/teacherbridge?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_REFRESH_SECRET="change-me-refresh-secret-different-from-access"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_DAYS="7"

# Google OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# Where to send the browser after Google OAuth (SPA route; tokens in URL fragment)
FRONTEND_OAUTH_REDIRECT="http://localhost:5173/auth/callback"

# S3-compatible storage (MinIO local)
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="teacher-bridge"
S3_FORCE_PATH_STYLE="true"
S3_PUBLIC_BASE_URL=""

# Voice pipeline (optional — mock mode when unset)
OPENAI_API_KEY=""
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION=""

# Web (copy to web/.env)
VITE_API_URL="http://localhost:3000/api/v1"
# Socket.IO connects directly to the API in dev (Vite proxy does not upgrade WS reliably)
VITE_WS_URL="http://localhost:3000"
